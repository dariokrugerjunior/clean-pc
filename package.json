{
  "name": "clean-pc",
  "version": "1.0.4",
  "description": "Limpador de disco Windows via terminal",
  "type": "module",
  "bin": {
    "clean-pc": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build:sea-bundle": "tsup --config tsup.sea.config.ts",
    "build:sea": "powershell -ExecutionPolicy Bypass -File build-sea.ps1 -Arch x64",
    "build:sea:x64": "powershell -ExecutionPolicy Bypass -File build-sea.ps1 -Arch x64",
    "build:sea:x86": "powershell -ExecutionPolicy Bypass -File build-sea.ps1 -Arch x86",
    "build:sea:all": "powershell -ExecutionPolicy Bypass -File build-sea.ps1 -Arch x64,x86",
    "typecheck": "tsc --noEmit",
    "scan": "tsx src/cli/index.ts scan --targets userTemp,windowsTemp,recycleBin,npm,logs",
    "dry": "tsx src/cli/index.ts clean --dry-run --targets userTemp,windowsTemp,recycleBin,npm,logs",
    "clean": "tsx src/cli/index.ts clean --targets userTemp,windowsTemp,recycleBin,npm,logs",
    "dev:scan": "tsx src/cli/index.ts scan",
    "dev:clean": "tsx src/cli/index.ts clean",
    "dev:dry": "tsx src/cli/index.ts clean --dry-run"
  },
  "dependencies": {
    "bytes": "^3.1.2",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.4.2",
    "ora": "^9.3.0",
    "p-limit": "^6.2.0"
  },
  "devDependencies": {
    "@types/bytes": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "postject": "^1.0.0-alpha.6",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.15.0"
  }
}
