{
  "name": "pc-cleaner",
  "version": "1.0.0",
  "description": "Windows disk cleaner CLI tool",
  "type": "module",
  "bin": {
    "pc-cleaner": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",

    "scan": "tsx src/cli/index.ts scan --targets userTemp,windowsTemp,recycleBin,npm,logs",
    "dry": "tsx src/cli/index.ts clean --dry-run --targets userTemp,windowsTemp,recycleBin,npm,logs",
    "clean": "tsx src/cli/index.ts clean --targets userTemp,windowsTemp,recycleBin,npm,logs",

    "dev:scan": "tsx src/cli/index.ts scan",
    "dev:clean": "tsx src/cli/index.ts clean",
    "dev:dry": "tsx src/cli/index.ts clean --dry-run"
  },
  "dependencies": {
    "bytes": "^3.1.2",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.4.2",
    "ora": "^9.3.0",
    "p-limit": "^6.2.0"
  },
  "devDependencies": {
    "@types/bytes": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.15.0"
  }
}
